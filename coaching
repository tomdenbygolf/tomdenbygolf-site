<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#0f1824">
<meta name="description" content="The Real Life Method™ — Break 80 without changing your swing. Tom Denby Golf coaching programme.">
<title>Break 80 Without Changing Your Swing | Tom Denby Golf</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,700;1,400&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">

<style>
:root {
  --navy: #1a2640;
  --navy-deep: #0f1824;
  --navy-mid: #243350;
  --navy-card: #1c2d45;
  --green: #3a6b4a;
  --green-bright: #5daa74;
  --tan: #c9a96e;
  --tan-light: #dfc18f;
  --cream: #f5ead8;
  --cream-dim: rgba(245,234,216,0.65);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--navy-deep);color:var(--cream);font-family:'Barlow',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:0.35}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(15,24,36,0.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(201,169,110,0.2);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-emblem{width:32px;height:32px;background:var(--tan);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:14px;color:var(--navy-deep)}
.nav-name{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;color:var(--cream)}
.nav-cta{background:var(--tan);color:var(--navy-deep);border:none;border-radius:6px;padding:8px 18px;font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;text-decoration:none;transition:0.2s}
.nav-cta:hover{background:var(--tan-light)}
@media(max-width:500px){.nav-cta{display:none}}

/* SHARED */
.section-inner{max-width:960px;margin:0 auto}
.section-tag{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--tan);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.section-tag::before{content:'';width:28px;height:2px;background:var(--tan);border-radius:1px}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(38px,8vw,58px);color:var(--cream);margin-bottom:16px;line-height:0.95}
.section-title em{color:var(--tan);font-style:italic;font-family:'Playfair Display',serif;font-weight:400}
.tan-rule{width:100%;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.4),transparent);margin:0}

.reveal{opacity:0;transform:translateY(24px);transition:0.6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* PRIMARY BUTTON */
.btn-primary{background:linear-gradient(135deg,var(--tan),var(--tan-light));color:var(--navy-deep);border:none;border-radius:8px;padding:20px 36px;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:10px;transition:0.2s;box-shadow:0 4px 20px rgba(201,169,110,0.3)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(201,169,110,0.42)}
.btn-ghost{background:transparent;color:var(--cream);border:1px solid rgba(245,234,216,0.25);border-radius:8px;padding:16px 32px;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:0.2s}
.btn-ghost:hover{border-color:var(--tan);color:var(--tan)}

/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
.hero{min-height:100svh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;padding:100px 24px 80px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 40%,rgba(58,107,74,0.14) 0%,transparent 70%),linear-gradient(180deg,var(--navy-deep) 0%,#0d1520 100%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(201,169,110,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(201,169,110,0.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%)}
.hero::after{content:'';position:absolute;top:80px;right:40px;width:100px;height:100px;border-top:1px solid rgba(201,169,110,0.18);border-right:1px solid rgba(201,169,110,0.18);pointer-events:none}
.hero::before{content:'';position:absolute;bottom:80px;left:40px;width:100px;height:100px;border-bottom:1px solid rgba(201,169,110,0.12);border-left:1px solid rgba(201,169,110,0.12);pointer-events:none}

.hero-inner{position:relative;z-index:2;max-width:820px;width:100%;margin:0 auto;text-align:center}

.hero-badge{display:inline-flex;align-items:center;gap:10px;background:rgba(201,169,110,0.1);border:1px solid rgba(201,169,110,0.25);border-radius:100px;padding:8px 20px;font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--tan);margin-bottom:28px}
.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--green-bright);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

.hero-eyeline{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,3vw,22px);color:rgba(245,234,216,0.55);margin-bottom:16px;line-height:1.5}

.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,12vw,96px);line-height:0.87;color:var(--cream);margin-bottom:14px;letter-spacing:1px}
.hero-title em{color:var(--tan);font-style:italic;font-family:'Playfair Display',serif;font-weight:400}

.hero-sub{font-size:clamp(15px,2.5vw,18px);line-height:1.75;color:rgba(245,234,216,0.7);max-width:600px;margin:0 auto 36px}

.hero-ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:16px}
.hero-hint{font-size:11px;color:rgba(245,234,216,0.3);letter-spacing:0.5px}

/* ═══════════════════════════════════════════
   SECTION 1 — THE PROBLEM
═══════════════════════════════════════════ */
.problem-section{padding:100px 24px;background:var(--navy);position:relative;overflow:hidden}
.problem-section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--tan),transparent)}

.problem-split{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-top:48px}
@media(max-width:720px){.problem-split{grid-template-columns:1fr;gap:40px}}

.problem-body{font-size:clamp(22px,4vw,32px);font-family:'Playfair Display',serif;font-style:italic;color:var(--cream);line-height:1.4;margin-bottom:28px}

.problem-list{display:flex;flex-direction:column;gap:0}
.problem-item{display:flex;align-items:flex-start;gap:14px;padding:18px 0;border-bottom:1px solid rgba(201,169,110,0.1);font-size:16px;line-height:1.55;color:rgba(245,234,216,0.75)}
.problem-item:last-child{border-bottom:none}
.problem-item-num{font-family:'Bebas Neue',sans-serif;font-size:22px;color:rgba(201,169,110,0.3);flex-shrink:0;line-height:1.1;margin-top:2px}
.problem-item strong{color:var(--cream);display:block;margin-bottom:3px;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:1px;text-transform:uppercase}

.problem-verdict{margin-top:40px;padding:28px 32px;background:rgba(201,169,110,0.06);border:1px solid rgba(201,169,110,0.2);border-radius:12px;border-left:3px solid var(--tan)}
.problem-verdict p{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,2.5vw,20px);color:var(--cream);line-height:1.55;margin-bottom:10px}
.problem-verdict span{font-size:12px;font-weight:700;color:var(--tan);letter-spacing:2px;text-transform:uppercase}

/* ═══════════════════════════════════════════
   SECTION 2 — THE REFRAME
═══════════════════════════════════════════ */
.reframe-section{padding:100px 24px;background:var(--navy-deep);position:relative}

.reframe-compare{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:48px;border-radius:16px;overflow:hidden;border:1px solid rgba(201,169,110,0.12)}
@media(max-width:600px){.reframe-compare{grid-template-columns:1fr}}

.reframe-col{padding:40px 36px}
.reframe-col.side-range{background:rgba(255,255,255,0.025)}
.reframe-col.side-course{background:var(--navy-mid)}

.reframe-col-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:28px;display:flex;align-items:center;gap:10px}
.side-range .reframe-col-label{color:rgba(245,234,216,0.3)}
.side-course .reframe-col-label{color:var(--tan)}

.reframe-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:20px;line-height:1.5}
.side-range .reframe-item{color:rgba(245,234,216,0.4);font-size:15px}
.side-course .reframe-item{color:rgba(245,234,216,0.9);font-size:15px;font-weight:500}

.reframe-verdict{padding:24px 36px;background:var(--navy-deep);border-top:1px solid rgba(201,169,110,0.15);grid-column:1/-1;text-align:center}
.reframe-verdict p{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,2.5vw,20px);color:var(--tan);line-height:1.55}

/* ═══════════════════════════════════════════
   SECTION 3 — THE METHOD
═══════════════════════════════════════════ */
.method-section{padding:100px 24px;background:var(--navy);position:relative;overflow:hidden}
.method-section::after{content:'METHOD';position:absolute;right:-10px;top:50%;transform:translateY(-50%) rotate(90deg);font-family:'Bebas Neue',sans-serif;font-size:140px;letter-spacing:10px;color:rgba(201,169,110,0.025);pointer-events:none;white-space:nowrap}
.method-section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--tan),transparent)}

.method-intro{font-size:clamp(18px,3vw,24px);font-family:'Playfair Display',serif;font-style:italic;color:rgba(245,234,216,0.7);max-width:560px;line-height:1.65;margin-bottom:56px}

.phases{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:rgba(201,169,110,0.08);border-radius:16px;overflow:hidden;border:1px solid rgba(201,169,110,0.12)}
@media(max-width:640px){.phases{grid-template-columns:1fr}}

.phase{background:var(--navy-deep);padding:36px 32px;position:relative;transition:background 0.25s}
.phase:hover{background:#111e30}
.phase::before{content:'';position:absolute;top:0;left:32px;right:32px;height:2px;background:linear-gradient(90deg,var(--tan),var(--green-bright));transform:scaleX(0);transition:transform 0.4s ease;border-radius:0 0 2px 2px}
.phase:hover::before{transform:scaleX(1)}

.phase-num{font-family:'Bebas Neue',sans-serif;font-size:64px;color:rgba(201,169,110,0.08);line-height:1;margin-bottom:4px;letter-spacing:-2px}
.phase-label{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tan);margin-bottom:10px}
.phase-title{font-family:'Playfair Display',serif;font-style:italic;font-size:18px;color:var(--cream);margin-bottom:10px;line-height:1.35}
.phase-body{font-size:14px;line-height:1.7;color:rgba(245,234,216,0.55)}

/* ═══════════════════════════════════════════
   SECTION 4 — PROOF
═══════════════════════════════════════════ */
.proof-section{padding:100px 24px;background:var(--navy-deep);position:relative}

.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
@media(max-width:720px){.proof-grid{grid-template-columns:1fr}}

.proof-card{background:var(--navy);border:1px solid rgba(201,169,110,0.15);border-radius:14px;padding:32px 28px;position:relative;transition:border-color 0.25s,transform 0.25s}
.proof-card:hover{border-color:rgba(201,169,110,0.35);transform:translateY(-4px)}
.proof-card::before{content:'\201C';position:absolute;top:16px;left:22px;font-family:'Playfair Display',serif;font-size:60px;color:rgba(201,169,110,0.18);line-height:1}

.proof-text{font-family:'Playfair Display',serif;font-style:italic;font-size:16px;line-height:1.65;color:var(--cream);margin-bottom:20px;padding-top:16px}
.proof-result{display:inline-flex;align-items:center;gap:8px;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tan)}
.proof-result::before{content:'';width:20px;height:2px;background:var(--tan);border-radius:1px}

/* ═══════════════════════════════════════════
   SECTION 5 + 6 — WHO IT'S FOR / NOT FOR
═══════════════════════════════════════════ */
.who-section{padding:100px 24px;background:var(--navy);position:relative;overflow:hidden}
.who-section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--tan),transparent)}

.who-split{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:48px}
@media(max-width:680px){.who-split{grid-template-columns:1fr}}

.who-card{border-radius:16px;padding:36px 32px;position:relative;overflow:hidden}
.who-card.is-for{background:var(--navy-mid);border:1px solid rgba(201,169,110,0.2)}
.who-card.is-not{background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.07)}
.who-card.is-for::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--tan),var(--green-bright))}

.who-card-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:24px}
.is-for .who-card-label{color:var(--tan)}
.is-not .who-card-label{color:rgba(245,234,216,0.3)}

.who-item{display:flex;align-items:flex-start;gap:14px;margin-bottom:18px;font-size:15px;line-height:1.55}
.who-item:last-child{margin-bottom:0}
.is-for .who-item{color:rgba(245,234,216,0.9)}
.is-not .who-item{color:rgba(245,234,216,0.4)}
.who-icon{font-size:16px;flex-shrink:0;margin-top:1px}

/* ═══════════════════════════════════════════
   SECTION 7 — THE OFFER
═══════════════════════════════════════════ */
.offer-section{padding:100px 24px;background:var(--navy-deep);position:relative;overflow:hidden}
.offer-section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--tan),transparent)}
.offer-section::after{content:'697';position:absolute;right:-20px;bottom:-20px;font-family:'Bebas Neue',sans-serif;font-size:240px;letter-spacing:-10px;color:rgba(201,169,110,0.03);pointer-events:none;line-height:1}

.offer-inner{max-width:840px;margin:0 auto}

.offer-name{display:inline-block;font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,5vw,40px);letter-spacing:4px;color:var(--tan);margin-bottom:6px}
.offer-tagline{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,2.5vw,20px);color:rgba(245,234,216,0.6);margin-bottom:40px}

.offer-body{font-size:16px;line-height:1.8;color:rgba(245,234,216,0.7);margin-bottom:36px;max-width:600px}

.offer-includes{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:48px}
@media(max-width:560px){.offer-includes{grid-template-columns:1fr}}

.offer-include{display:flex;align-items:flex-start;gap:14px;padding:20px 22px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,169,110,0.12);border-radius:10px;font-size:14px;line-height:1.55;color:rgba(245,234,216,0.8);transition:border-color 0.25s}
.offer-include:hover{border-color:rgba(201,169,110,0.3)}
.offer-include-icon{font-size:20px;flex-shrink:0}
.offer-include strong{display:block;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--tan);margin-bottom:4px}

/* Price block */
.price-block{background:var(--navy-mid);border:1px solid rgba(201,169,110,0.25);border-radius:16px;padding:40px 36px;position:relative;overflow:hidden;margin-bottom:32px}
.price-block::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--tan),var(--green-bright))}

.price-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--tan);margin-bottom:12px}
.price-main{font-family:'Bebas Neue',sans-serif;font-size:clamp(52px,10vw,80px);color:var(--cream);line-height:0.9;margin-bottom:4px;letter-spacing:-1px}
.price-main span{font-size:0.4em;vertical-align:top;margin-top:16px;display:inline-block;color:var(--tan);font-family:'Barlow Condensed',sans-serif;letter-spacing:2px}
.price-desc{font-size:14px;color:rgba(245,234,216,0.6);line-height:1.65;margin-bottom:24px;max-width:480px}

.price-divider{width:100%;height:1px;background:rgba(201,169,110,0.15);margin:24px 0}

.price-alt-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(245,234,216,0.4);margin-bottom:10px}
.price-alt{display:flex;align-items:center;gap:12px}
.price-alt-num{font-family:'Bebas Neue',sans-serif;font-size:36px;color:rgba(245,234,216,0.6);letter-spacing:-1px}
.price-alt-detail{font-size:13px;color:rgba(245,234,216,0.4);line-height:1.5}

/* ═══════════════════════════════════════════
   FINAL CTA
═══════════════════════════════════════════ */
.final-cta{padding:120px 24px;background:var(--navy);position:relative;overflow:hidden;text-align:center}
.final-cta::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--tan),transparent)}
.final-cta::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.2),transparent)}

/* Large decorative text */
.cta-bg-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Bebas Neue',sans-serif;font-size:clamp(100px,20vw,200px);color:rgba(201,169,110,0.03);white-space:nowrap;pointer-events:none;letter-spacing:5px;z-index:0}

.final-cta-inner{position:relative;z-index:1;max-width:680px;margin:0 auto}

.cta-hook{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,3vw,22px);color:rgba(245,234,216,0.5);margin-bottom:20px;line-height:1.5}

.cta-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,10vw,80px);color:var(--cream);line-height:0.9;margin-bottom:20px;letter-spacing:1px}
.cta-title em{color:var(--tan);font-style:italic;font-family:'Playfair Display',serif;font-weight:400}

.cta-dialogue{display:inline-block;background:rgba(201,169,110,0.07);border:1px solid rgba(201,169,110,0.2);border-left:3px solid var(--tan);border-radius:0 8px 8px 0;padding:16px 24px;margin:24px auto 32px;font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,2.5vw,20px);color:var(--cream);line-height:1.55;text-align:left;max-width:520px}

.cta-reframe{font-size:15px;color:rgba(245,234,216,0.65);line-height:1.75;margin-bottom:36px}
.cta-reframe strong{color:var(--cream);font-family:'Barlow Condensed',sans-serif;font-weight:700;letter-spacing:1px;text-transform:uppercase;font-style:normal}

.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:16px}
.cta-note{font-size:12px;color:rgba(245,234,216,0.3);letter-spacing:0.5px;font-style:italic;margin-top:20px}

/* MOBILE BOTTOM NAV */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:rgba(15,24,36,0.96);backdrop-filter:blur(16px);border-top:1px solid rgba(201,169,110,0.2);display:flex;height:64px;padding-bottom:env(safe-area-inset-bottom);z-index:99}
@media(min-width:700px){.bottom-nav{display:none}}
